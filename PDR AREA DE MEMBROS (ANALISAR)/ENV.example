# =====================================================
# .env / .env.local
# =====================================================
# Variáveis com prefixo VITE_ vão pro front (no bundle)
# Variáveis SEM prefixo VITE_ ficam só no servidor/build
#
# IMPORTANTE: Configure as SEM prefixo VITE_ como Edge Function
# Secrets no Supabase Dashboard > Edge Functions > Secrets
# (NÃO no .env do front!)
# =====================================================

# -----------------------------------------------------
# SUPABASE (front + edge functions)
# -----------------------------------------------------
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxx

# Esta vai SÓ em Edge Functions Secrets:
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxx (CONFIDENCIAL — nunca expor)

# -----------------------------------------------------
# IA (Edge Functions Secrets — NÃO ir pro front)
# -----------------------------------------------------
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------
# WHATSAPP (Edge Functions Secrets)
# -----------------------------------------------------
# Opção A: UAZAPI
# UAZAPI_URL=https://yourinstance.uazapi.com
# UAZAPI_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Group JIDs (não sensível, pode ir aqui)
# GROUP_PAIN_MAIN=120363xxxxx@g.us
# GROUP_PAIN_SUPORTE=120363xxxxx@g.us

# Opção B: Cloud API oficial Meta
# META_PHONE_NUMBER_ID=
# META_TOKEN=
# META_BUSINESS_ID=
# META_VERIFY_TOKEN=

# -----------------------------------------------------
# VÍDEO (Edge Functions Secrets)
# -----------------------------------------------------
# PANDA_API_KEY=xxxx
# PANDA_FOLDER_ID=xxxx

# -----------------------------------------------------
# TRANSCRIÇÃO (Edge Functions Secrets)
# -----------------------------------------------------
# ASSEMBLYAI_API_KEY=

# -----------------------------------------------------
# PAGAMENTO (Edge Functions Secrets)
# -----------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_xxx (ou sk_test_xxx em dev)
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# HOTMART_WEBHOOK_SECRET=
# KIWIFY_WEBHOOK_SECRET=

# -----------------------------------------------------
# REUNIÕES (Edge Functions Secrets)
# -----------------------------------------------------
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_ACCOUNT_ID=
# ZOOM_WEBHOOK_SECRET=

# -----------------------------------------------------
# EMAIL (Edge Functions Secrets)
# -----------------------------------------------------
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=ola@seudominio.com

# -----------------------------------------------------
# OBSERVABILIDADE (front pode ter, mas DSN não é sensível)
# -----------------------------------------------------
VITE_SENTRY_DSN=https://xxxxx@xxx.ingest.sentry.io/xxxxx

# -----------------------------------------------------
# OUTROS
# -----------------------------------------------------
VITE_SITE_URL=https://seuapp.com  # URL do site em produção
